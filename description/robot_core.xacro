<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot">

    <!-- ================= MATERIALS ================= -->
    <material name="white"><color rgba="1 1 1 1"/></material>
    <material name="black"><color rgba="0 0 0 1"/></material>
    <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>

    <!-- ================= PROPERTIES ================= -->
    <xacro:property name="box_length" value="0.394"/>
    <xacro:property name="box_width"  value="0.300"/>
    <xacro:property name="box_height" value="0.280"/>

    <!-- ================= BASE LINK ================= -->
    <link name="base_link">
        <inertial>
            <origin xyz="0 0 0"/>
            <mass value="0.5"/>
            <inertia ixx="0.002" iyy="0.002" izz="0.002"
                     ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <!-- ================= CHASSIS ================= -->
    <joint name="chassis_joint" type="fixed">
        <origin xyz="-0.115 0 0"/>
        <parent link="base_link"/>
        <child link="chassis_link"/>
    </joint>

    <link name="chassis_link">
        <visual>
            <origin xyz="${box_length/2} 0 ${box_height/2}"/>
            <geometry>
                <box size="${box_length} ${box_width} ${box_height}"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="${box_length/2} 0 ${box_height/2}"/>
            <geometry>
                <box size="${box_length} ${box_width} ${box_height}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="${box_length/2} 0 ${box_height/2}"/>
            <mass value="8.0"/>
            <inertia
                ixx="${(1/12.0)*8*(box_width*box_width + box_height*box_height)}"
                iyy="${(1/12.0)*8*(box_length*box_length + box_height*box_height)}"
                izz="${(1/12.0)*8*(box_length*box_length + box_width*box_width)}"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <!-- ================= LEFT MOTOR ================= -->
    <joint name="left_motor_joint" type="fixed">
        <origin xyz="0 0.102 0"/>
        <parent link="base_link"/>
        <child link="left_motor_link"/>
    </joint>

    <link name="left_motor_link">
        <visual>
            <origin xyz="0 0.036 -0.023" rpy="${pi/2} 0 0"/>
            <geometry>
                <cylinder radius="0.023" length="0.126"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 0.036 -0.023" rpy="${pi/2} 0 0"/>
            <geometry>
                <cylinder radius="0.023" length="0.126"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0.036 -0.023"/>
            <mass value="0.6"/>
            <inertia
                ixx="0.0009" iyy="0.0004" izz="0.0009"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <!-- ================= LEFT WHEEL ================= -->
    <joint name="left_wheel_joint" type="continuous">
        <origin xyz="0 0.082 -0.023" rpy="-${pi/2} 0 0"/>
        <parent link="left_motor_link"/>
        <child link="left_wheel_link"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="0.04" length="0.035"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.04" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.4"/>
            <inertia
                ixx="0.00016" iyy="0.00032" izz="0.00016"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <!-- ================= RIGHT MOTOR ================= -->
    <joint name="right_motor_joint" type="fixed">
        <origin xyz="0 -0.102 0"/>
        <parent link="base_link"/>
        <child link="right_motor_link"/>
    </joint>

    <link name="right_motor_link">
        <visual>
            <origin xyz="0 -0.036 -0.023" rpy="-${pi/2} 0 0"/>
            <geometry>
                <cylinder radius="0.023" length="0.126"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 -0.036 -0.023" rpy="-${pi/2} 0 0"/>
            <geometry>
                <cylinder radius="0.023" length="0.126"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 -0.036 -0.023"/>
            <mass value="0.6"/>
            <inertia
                ixx="0.0009" iyy="0.0004" izz="0.0009"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <!-- ================= RIGHT WHEEL ================= -->
    <joint name="right_wheel_joint" type="continuous">
        <origin xyz="0 -0.082 -0.023" rpy="${pi/2} 0 0"/>
        <parent link="right_motor_link"/>
        <child link="right_wheel_link"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="0.04" length="0.035"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.04" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.4"/>
            <inertia
                ixx="0.00016" iyy="0.00032" izz="0.00016"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <!-- ================= CASTER ================= -->
    <joint name="caster_wheel_joint" type="fixed">
        <origin xyz="0.250 0 -0.0315"/>
        <parent link="base_link"/>
        <child link="caster_wheel_link"/>
    </joint>

    <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="0.0315"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.0315"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <inertia
                ixx="0.00008" iyy="0.00008" izz="0.00008"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

</robot>
