<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot">

    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>
    
    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>
    
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="grey">
         <color rgba="0.5 0.5 0.5 1"/>
    </material>

    <material name="wood">
         <color rgba="0.5 0.3 0.1 1"/>
    </material>


    <!-- Box dimensions -->
    <xacro:property name="box_length" value="0.394" />
    <xacro:property name="box_width" value="0.300" />
    <xacro:property name="box_height" value="0.280" />
    <xacro:property name="wall_thickness" value="0.012" />
    <xacro:property name="wall_mass" value="1.5" />
    
    <!-- Additional mass properties -->
    <xacro:property name="base_mass" value="2.0" />
    <xacro:property name="motor_mass" value="1.5" />
    <xacro:property name="wheel_mass" value="0.5" />
    <xacro:property name="caster_mass" value="0.2" />

    <!-- World link (fixed reference) -->
    <link name="world"/>

    <!-- Base joint connecting to world -->
    <joint name="base_joint" type="fixed">
        <origin xyz="0 0 0.063" rpy="0 0 0"/>
        <parent link="world"/>
        <child link="base_link"/>        
    </joint>

    <!-- Base Link (reference frame at ground level - base plate) -->
    <link name="base_link">
        <visual>
            <origin xyz="0.118 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.394 0.300 0.012"/>
            </geometry>
            <material name="wood"/>
        </visual>
        <collision>
            <origin xyz="0.118 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.394 0.300 0.012"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.118 0 0" rpy="0 0 0"/>
            <mass value="${base_mass}" />
            <inertia ixx="${(base_mass/12) * (0.012*0.012 + box_width*box_width)}" 
                     ixy="0.0" ixz="0.0"
                     iyy="${(base_mass/12) * (box_length*box_length + 0.012*0.012)}" 
                     iyz="0.0"
                     izz="${(base_mass/12) * (box_length*box_length + box_width*box_width)}" />
        </inertial>
    </link>

    <!-- LEFT WALL -->
    <joint name="left_joint" type="fixed">
        <origin xyz="0.118 ${-(box_width/2 - wall_thickness/2)} ${box_height/2}" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="left_link"/>        
    </joint>

    <link name="left_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${box_length} ${wall_thickness} ${box_height}"/>
            </geometry>
            <material name="wood"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${box_length} ${wall_thickness} ${box_height}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${wall_mass}" />
            <inertia ixx="${(wall_mass/12) * (wall_thickness*wall_thickness + box_height*box_height)}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(wall_mass/12) * (box_length*box_length + box_height*box_height)}" 
                     iyz="0.0" 
                     izz="${(wall_mass/12) * (box_length*box_length + wall_thickness*wall_thickness)}" />
        </inertial>
    </link>

    <!-- RIGHT WALL -->
    <joint name="right_joint" type="fixed">
        <origin xyz="0.118 ${box_width/2 - wall_thickness/2} ${box_height/2}" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="right_link"/>        
    </joint>

    <link name="right_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${box_length} ${wall_thickness} ${box_height}"/>
            </geometry>
            <material name="wood"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${box_length} ${wall_thickness} ${box_height}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${wall_mass}" />
            <inertia ixx="${(wall_mass/12) * (wall_thickness*wall_thickness + box_height*box_height)}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(wall_mass/12) * (box_length*box_length + box_height*box_height)}" 
                     iyz="0.0" 
                     izz="${(wall_mass/12) * (box_length*box_length + wall_thickness*wall_thickness)}" />
        </inertial>
    </link>

    <!-- FRONT WALL -->
    <joint name="front_joint" type="fixed">
        <origin xyz="${box_length/2 - wall_thickness/2 + 0.118} 0 ${box_height/2}" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="front_link"/>        
    </joint>

    <link name="front_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${wall_thickness} ${box_width - 2*wall_thickness} ${box_height}"/>
            </geometry>
            <material name="wood"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${wall_thickness} ${box_width - 2*wall_thickness} ${box_height}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${wall_mass}" />
            <inertia ixx="${(wall_mass/12) * ((box_width - 2*wall_thickness)*(box_width - 2*wall_thickness) + box_height*box_height)}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(wall_mass/12) * (wall_thickness*wall_thickness + box_height*box_height)}" 
                     iyz="0.0" 
                     izz="${(wall_mass/12) * (wall_thickness*wall_thickness + (box_width - 2*wall_thickness)*(box_width - 2*wall_thickness))}" />
        </inertial>
    </link>

    <!-- BACK WALL -->
    <joint name="back_joint" type="fixed">
        <origin xyz="${-(box_length/2 - wall_thickness/2) + 0.118} 0 ${box_height/2}" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="back_link"/>        
    </joint>

    <link name="back_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${wall_thickness} ${box_width - 2*wall_thickness} ${box_height}"/>
            </geometry>
            <material name="wood"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${wall_thickness} ${box_width - 2*wall_thickness} ${box_height}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${wall_mass}" />
            <inertia ixx="${(wall_mass/12) * ((box_width - 2*wall_thickness)*(box_width - 2*wall_thickness) + box_height*box_height)}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(wall_mass/12) * (wall_thickness*wall_thickness + box_height*box_height)}" 
                     iyz="0.0" 
                     izz="${(wall_mass/12) * (wall_thickness*wall_thickness + (box_width - 2*wall_thickness)*(box_width - 2*wall_thickness))}" />
        </inertial>
    </link>


    <!-- LEFT MOTOR -->
    <joint name="left_motor_joint" type="fixed">
        <origin xyz="0 ${box_width/2 - wall_thickness/2 - 0.048} 0" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="left_motor_link"/>        
    </joint>

    <link name="left_motor_link">
        <visual>
            <origin xyz="0 0.036 -0.023" rpy="${pi/2} 0 0"/>
            <geometry>
                <cylinder radius="0.023" length="0.126"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 0.036 -0.023" rpy="${pi/2} 0 0"/>
            <geometry>
                <cylinder radius="0.023" length="0.126"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0.036 -0.023" rpy="${pi/2} 0 0"/>
            <mass value="${motor_mass}" />
            <inertia ixx="${(motor_mass/12) * (3*0.023*0.023 + 0.126*0.126)}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(motor_mass/12) * (3*0.023*0.023 + 0.126*0.126)}" 
                     iyz="0.0" 
                     izz="${(motor_mass/2) * (0.023*0.023)}" />
        </inertial>
    </link>

    <!-- LEFT Wheel -->
    <joint name="left_wheel_joint" type="continuous">
        <origin xyz="0 ${(0.120 - 0.038)} -0.023" rpy="-${pi/2} 0 0"/>
        <parent link="left_motor_link"/>
        <child link="left_wheel_link"/>   
        <axis xyz="0 0 1"/>     
    </joint>

    <link name="left_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.04" length="0.035"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.04" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${wheel_mass}" />
            <inertia ixx="${(wheel_mass/12) * (3*0.04*0.04 + 0.035*0.035)}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(wheel_mass/12) * (3*0.04*0.04 + 0.035*0.035)}" 
                     iyz="0.0" 
                     izz="${(wheel_mass/2) * (0.04*0.04)}" />
        </inertial>
    </link>

    <!-- Right MOTOR -->
    <joint name="right_motor_joint" type="fixed">
        <origin xyz="0 -${box_width/2 - wall_thickness/2 - 0.048} 0" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="right_motor_link"/>        
    </joint>

    <link name="right_motor_link">
        <visual>
            <origin xyz="0 -0.036 -0.023" rpy="-${pi/2} 0 0"/>
            <geometry>
                <cylinder radius="0.023" length="0.126"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 -0.036 -0.023" rpy="-${pi/2} 0 0"/>
            <geometry>
                <cylinder radius="0.023" length="0.126"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 -0.036 -0.023" rpy="-${pi/2} 0 0"/>
            <mass value="${motor_mass}" />
            <inertia ixx="${(motor_mass/12) * (3*0.023*0.023 + 0.126*0.126)}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(motor_mass/12) * (3*0.023*0.023 + 0.126*0.126)}" 
                     iyz="0.0" 
                     izz="${(motor_mass/2) * (0.023*0.023)}" />
        </inertial>
    </link>
    

    <!-- RIGHT Wheel -->
    <joint name="right_wheel_joint" type="continuous">
        <origin xyz="0 -${(0.120 - 0.038)} -0.023" rpy="${pi/2} 0 0"/>
        <parent link="right_motor_link"/>
        <child link="right_wheel_link"/>   
        <axis xyz="0 0 1"/>     
    </joint>

    <link name="right_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.04" length="0.035"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.04" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${wheel_mass}" />
            <inertia ixx="${(wheel_mass/12) * (3*0.04*0.04 + 0.035*0.035)}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(wheel_mass/12) * (3*0.04*0.04 + 0.035*0.035)}" 
                     iyz="0.0" 
                     izz="${(wheel_mass/2) * (0.04*0.04)}" />
        </inertial>
    </link>


    <!-- Caster Wheel -->
    <joint name="caster_wheel_joint" type="fixed">
        <origin xyz="0.269 0 -0.0315" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="caster_wheel_link"/>        
    </joint>

    <link name="caster_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.0315"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.0315"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${caster_mass}" />
            <inertia ixx="${(2/5) * caster_mass * 0.0315 * 0.0315}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(2/5) * caster_mass * 0.0315 * 0.0315}" 
                     iyz="0.0" 
                     izz="${(2/5) * caster_mass * 0.0315 * 0.0315}" />
        </inertial>
    </link>

</robot>